rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /Retailers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /Customers/{customerId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /EmiDetails/{emiId} {
      // Reads are allowed for any authenticated user because client-side queries are already filtered.
      // Securing list queries on this collection would require data model changes.
      allow read: if request.auth != null;
      // Creates are only allowed if the associated customer belongs to the retailer.
      allow create: if request.auth != null && get(/databases/$(database)/documents/Customers/$(request.resource.data.customerId)).data.uid == request.auth.uid;
    }

    match /Notifications/{notificationId} {
      allow create: if request.auth != null && request.resource.data.retailerId == request.auth.uid;
      allow read: if request.auth != null && resource.data.retailerId == request.auth.uid;
    }

    match /Payments/{paymentId} {
      // Users can read their own payment records (for history/receipts)
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      // Writes are restricted to server-side only (Firebase Admin SDK)
      // This prevents client-side manipulation of payment records
      allow write: if false;
    }
  }
}
